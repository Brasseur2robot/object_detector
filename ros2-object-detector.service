[Unit]
Description=ROS2 Object Detector
After=network.target

[Service]
Type=simple
User=user
WorkingDirectory=/home/user/ros2_packages

Environment="HOME=/home/user"

ExecStart=/bin/bash -c 'source /opt/ros/humble/setup.bash && source /home/user/ros2_packages/install/setup.bash && ros2 launch object_detector object_detector.launch.py'

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
